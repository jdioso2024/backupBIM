# ─────────────────────────────────────────────────────────────────────────────
# PMB Terpadu — Kubernetes Secret (TEMPLATE)
#
# Copy ke k8s-secret.yaml di server (file nyata TIDAK di-commit ke git), lalu:
#   microk8s kubectl apply -f k8s-secret.yaml
#
# Generate SECRET_KEY:
#   py -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: pmb-terpadu-secret
  namespace: default
type: Opaque
stringData:
  # ── Django core ──
  SECRET_KEY: "GANTI_DENGAN_SECRET_KEY_RANDOM_50_KARAKTER"
  DEBUG: "False"
  ALLOWED_HOSTS: "ods.bim.ac.id,pmb-terpadu.ums.ac.id,10.3.11.53"
  CSRF_TRUSTED_ORIGINS: "https://ods.bim.ac.id,https://pmb-terpadu.ums.ac.id"

  # ── Database MSSQL ──
  DB_HOST: "10.3.11.70,1433"
  DB_USER: "wuryanto"
  DB_PASSWORD: "GANTI_PASSWORD_DB"
  DB_NAME: "pmb_terpadu"
  DB_PORT: "1433"

  # ── Database lama pmb.bim.ac.id (MySQL, opsional untuk migrasi) ──
  OLD_DB_HOST: "10.3.11.24"
  OLD_DB_PORT: "3306"
  OLD_DB_USER: "GANTI_USER_MYSQL"
  OLD_DB_PASSWORD: "GANTI_PASSWORD_MYSQL"
  OLD_DB_NAME: "pmbbimac_pmb"

  # ── HTTPS / SSL ──
  SECURE_SSL_REDIRECT: "True"
  SECURE_HSTS_SECONDS: "300"

  # ── Email (opsional) ──
  EMAIL_HOST: ""
  EMAIL_PORT: "587"
  EMAIL_HOST_USER: ""
  EMAIL_HOST_PASSWORD: ""
  EMAIL_USE_TLS: "True"
  DEFAULT_FROM_EMAIL: "PMB UMS <pmb@ums.ac.id>"

  # ── Integrasi Sistem Keuangan (push tagihan biaya pendaftaran saat CAMA daftar) ──
  # KEUANGAN_ODS_TOKEN harus SAMA dengan ODS_INBOUND_TOKEN di secret keuangan.
  # Kosongkan keduanya untuk menonaktifkan integrasi (client jadi no-op).
  KEUANGAN_API_BASE: "https://keuangan.bim.ac.id"
  KEUANGAN_ODS_TOKEN: ""
