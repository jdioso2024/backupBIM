# ── PMB Terpadu — Production Environment Template ─────────────────────────────
# Copy file ini ke `.env` di server produksi, lalu isi nilainya.
# JANGAN commit file .env production ke git.

# ── Django core ──
# Generate 50+ karakter acak:
#   py -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=GANTI_DENGAN_SECRET_KEY_RANDOM_MIN_50_KARAKTER
DEBUG=False
ALLOWED_HOSTS=ods.bim.ac.id,pmb-terpadu.ums.ac.id,10.3.11.53
CSRF_TRUSTED_ORIGINS=https://ods.bim.ac.id,https://pmb-terpadu.ums.ac.id

# ── Database (MSSQL) ──
DB_HOST=10.3.11.x,1433
DB_USER=pmb_user
DB_PASSWORD=GANTI_PASSWORD_KUAT
DB_NAME=pmb_terpadu
DB_PORT=1433

# ── Database lama pmb.bim.ac.id (MySQL — untuk migrasi data pendaftar lama) ──
# Isi saat perlu jalankan `manage.py migrate_bim_2026`. Setelah migrasi selesai,
# bisa dihapus/kosongkan.
OLD_DB_HOST=10.3.11.24
OLD_DB_PORT=3306
OLD_DB_USER=GANTI_USER_MYSQL
OLD_DB_PASSWORD=GANTI_PASSWORD_MYSQL
OLD_DB_NAME=pmbbimac_pmb

# ── HTTPS / SSL (di balik reverse proxy Nginx/Traefik) ──
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# ── Email (untuk fitur reset password dll; kosongkan jika tidak pakai) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=pmb@bim.ac.id
EMAIL_HOST_PASSWORD=app_password_bukan_password_akun
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=PMB BIM <pmb@bim.ac.id>
