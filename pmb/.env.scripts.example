# Contoh environment variable untuk skrip deployment Python.
# Salin ke .env.scripts, isi nilainya, dan JANGAN commit file aslinya.
#
# Cara pakai (PowerShell):
#   $env:NFS_SSH_USER="..."; $env:NFS_SSH_PASS="..."; python upload_to_nfs.py
# Cara pakai (bash):
#   export NFS_SSH_USER=... NFS_SSH_PASS=... && python upload_to_nfs.py

# TrueNAS API (chown_nfs.py) — host 10.3.11.52
TRUENAS_USER=root
TRUENAS_PASS=

# SSH/SFTP NFS server (upload_to_nfs.py, fix_env_nfs.py, deploy_setting*.py) — host 10.3.11.52
NFS_SSH_USER=admin
NFS_SSH_PASS=

# SSH Nginx server (reset_admin_password.py) — host 10.3.11.60
NGINX_SSH_USER=wury
NGINX_SSH_PASS=

# MariaDB (reset_admin_password.py) — host 10.3.11.24
DB_USER=pmb_bimacid
DB_PASS=

# Password admin/superadmin baru yang akan di-set (reset_admin_password.py)
NEW_ADMIN_PASSWORD=
